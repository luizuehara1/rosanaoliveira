rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    
    function isSignedIn() {
      return request.auth != null;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    // Lead Validation Blueprint
    function isValidLead(data) {
      return data.keys().hasAll(['name', 'whatsapp', 'email', 'createdAt'])
        && (data.keys().size() == 4 || (data.keys().size() == 5 && data.keys().hasAll(['source'])))
        && data.name is string && data.name.size() > 0 && data.name.size() <= 100
        && data.whatsapp is string && data.whatsapp.size() >= 8 && data.whatsapp.size() <= 20
        && data.email is string && data.email.size() <= 100 && data.email.matches('^.+@.+$')
        && data.createdAt == request.time;
    }

    // --- Collections ---

    match /leads/{leadId} {
      // Allowed for public creation (landing page lead capture)
      allow create: if isValidId(leadId) && isValidLead(incoming());
      
      // Reads are restricted to the admin (the user luiz.uehara1@gmail.com)
      // This allows the professional to view leads in the Firebase Console or a protected route
      allow read, list: if isSignedIn() && request.auth.token.email == 'luiz.uehara1@gmail.com' && request.auth.token.email_verified == true;
    }
  }
}
